# Ejemplo de variables de entorno. 
# Renombra una copia de este archivo como ".env" y llena los datos con tus propias credenciales.

# --- FIREBASE ---
VITE_FIREBASE_API_KEY="tu_api_key_aqui"
VITE_FIREBASE_AUTH_DOMAIN="tu-dominio.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="tu-proyecto-id"
VITE_FIREBASE_STORAGE_BUCKET="tu-bucket.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="sender_id_numerico"
VITE_FIREBASE_APP_ID="app_id_largo"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXX"

# --- GEMINI API ---
VITE_GEMINI_API_KEY="tu_google_gemini_api_key_aqui"
